# =============================================================================
# OARS — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git. It is already in .gitignore.
#
# FREE TIER SETUP GUIDE — each service below has a free tier.
# Follow the instructions to get each key at zero cost.
# =============================================================================


# -----------------------------------------------------------------------------
# CLERK — Authentication
# Free tier: up to 10,000 Monthly Active Users
# -----------------------------------------------------------------------------
# 1. Go to https://clerk.com and sign up (free)
# 2. Create a new application
# 3. Go to "API Keys" in the sidebar
# 4. Copy "Publishable Key" → NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# 5. Copy "Secret Key"      → CLERK_SECRET_KEY
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


# -----------------------------------------------------------------------------
# SUPABASE — Database (PostgreSQL + pgvector)
# Free tier: 500MB database, 2 projects, 50,000 MAU
# -----------------------------------------------------------------------------
# 1. Go to https://supabase.com and sign up (free)
# 2. Create a new project (choose a region close to you)
# 3. Go to Project Settings → API
# 4. Copy "Project URL"      → NEXT_PUBLIC_SUPABASE_URL
# 5. Copy "anon public" key  → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 6. Copy "service_role" key → SUPABASE_SERVICE_ROLE_KEY
#    (⚠ service_role is SECRET — never expose it client-side)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# CLOUDFLARE R2 — Object Storage (PDFs, audio, video, exports)
# Free tier: 10GB storage, zero egress fees
# -----------------------------------------------------------------------------
# 1. Go to https://dash.cloudflare.com and sign up (free)
# 2. Go to R2 Object Storage → Create Bucket
# 3. Name your bucket (e.g. "oars-uploads") → R2_BUCKET_NAME
# 4. Go to R2 → Manage R2 API Tokens → Create API Token
#    - Set permissions: Object Read & Write
#    - Copy "Access Key ID"     → R2_ACCESS_KEY_ID
#    - Copy "Secret Access Key" → R2_SECRET_ACCESS_KEY
# 5. Your account ID is in the URL: dash.cloudflare.com/<account_id>
#    Copy it → R2_ACCOUNT_ID
# 6. To make files publicly accessible:
#    - In your bucket → Settings → Public Access → Allow Access
#    - Copy the public URL (e.g. https://pub-xxx.r2.dev) → R2_PUBLIC_URL
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=


# -----------------------------------------------------------------------------
# RESEND — Transactional Email (report notifications)
# Free tier: 3,000 emails/month, 1 custom domain
# -----------------------------------------------------------------------------
# 1. Go to https://resend.com and sign up (free)
# 2. Go to API Keys → Create API Key
# 3. Copy the key → RESEND_API_KEY
# NOTE: For testing, you can skip this entirely — email is not required
#       for core functionality. Add it only when notifications are needed.
# -----------------------------------------------------------------------------
RESEND_API_KEY=


# -----------------------------------------------------------------------------
# ANTHROPIC — Claude AI (reasoning, synthesis, report generation)
# No free tier — pay-as-you-go. Claude 3.5 Haiku is the cheapest option.
# FOR TESTING: mock responses are used when this key is absent.
# -----------------------------------------------------------------------------
# 1. Go to https://console.anthropic.com and sign up
# 2. Go to API Keys → Create Key
# 3. Copy the key → ANTHROPIC_API_KEY
# TIP: Start with claude-haiku-3-5 for testing (~$0.001 per 1K tokens)
#      Only upgrade to Sonnet/Opus for production use.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# GOOGLE GEMINI — Multimodal AI (vision/audio extraction)
# Free tier: 15 requests/minute on Gemini 1.5 Flash via Google AI Studio
# -----------------------------------------------------------------------------
# 1. Go to https://aistudio.google.com and sign in with Google (free)
# 2. Click "Get API key" → Create API key
# 3. Copy the key → GEMINI_API_KEY
# NOTE: Gemini 1.5 Flash is FREE with rate limits — ideal for testing
#       vision and audio extraction without any cost.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
